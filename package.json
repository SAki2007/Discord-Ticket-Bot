{
  "name": "discord-ticket-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord ticket bot with automatic staff assignment and Supabase persistence.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "register-commands": "tsx src/bot/registerCommands.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2",
    "discord.js": "^14",
    "dotenv": "^17",
    "pino": "^9",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsx": "^4",
    "typescript": "^5"
  }
}
